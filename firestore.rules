rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. GLOBAL SAFETY NET
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. HELPERS
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Checking if the user matches the bootstrapped Admin address or is admin in users
    function isAdmin() {
      return isSignedIn() && (
        (isEmailVerified() && request.auth.token.email == 'tudojonas38@gmail.com') ||
        (request.auth.token.email == 'pastel@x.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isEmployee() {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'employee' &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active')
      );
    }

    function isMotoboy() {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'motoboy' &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. PRODUCTS COLLECTION
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(productId);
    }

    // 4. SETTINGS COLLECTION
    match /settings/{docId} {
      allow read: if true;
      allow write, create, update: if isAdmin();
    }

    // 5. ORDERS COLLECTION
    match /orders/{orderId} {
      // Any customer can read individual order details to track their order
      allow get: if isValidId(orderId);
      
      // Only administrators or registered employees/motoboys can list all orders
      allow list: if isAdmin() || isEmployee() || isMotoboy();

      // Submit an order is public. Basic type/integrity validation
      allow create: if isValidId(orderId) 
        && incoming().id == orderId
        && incoming().customerName is string
        && incoming().customerName.size() <= 100
        && incoming().customerPhone is string
        && incoming().customerPhone.size() <= 30
        && incoming().paymentMethod is string
        && incoming().deliveryMethod is string
        && incoming().status == 'pending';

      // Updates (like status changes or assignment) can be done by admins, employees or motoboys
      allow update: if (isAdmin() || isEmployee() || isMotoboy()) && isValidId(orderId);
      allow delete: if isAdmin() && isValidId(orderId);
    }

    // 6. CUSTOMERS COLLECTION
    match /customers/{customerId} {
      allow read, update, delete: if isAdmin() || isEmployee();
      allow create: if isValidId(customerId)
        && incoming().name is string
        && incoming().phone is string;
    }

    // 7. COUPONS COLLECTION
    match /coupons/{couponId} {
      allow get: if true;
      allow list: if isAdmin() || isEmployee();
      allow create, update, delete: if isAdmin() && isValidId(couponId);
    }

    // 8. CATEGORIES COLLECTION
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(categoryId);
    }

    // 9. USERS MATCH
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isEmployee() || isMotoboy());
      allow create, update: if (isAdmin() || request.auth.uid == userId) && isValidId(userId);
      allow delete: if isAdmin() && isValidId(userId);
    }
  }
}
